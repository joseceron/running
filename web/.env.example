# ─── Liebre — variables de entorno del frontend (web/) ───
# Copia este archivo a .env.local y rellena los valores.
# NUNCA commitees .env.local (está en .gitignore).

# URL base de la API de Liebre (FastAPI sobre Cloud Run)
# Dev local: http://localhost:8080
# Prod:      https://api.liebre.run
NEXT_PUBLIC_LIEBRE_API=http://localhost:8080

# Dominio público del frontend
NEXT_PUBLIC_SITE_URL=https://liebre.run

# ─── Firebase Web SDK (Console > Project Settings > General > Your apps) ───
# Para obtener estos valores:
# 1. https://console.firebase.google.com/project/liebre-mvp/settings/general
# 2. Bajo "Your apps" → click "Add app" → ícono Web (</>)
# 3. App nickname: "Liebre Web"
# 4. Firebase Hosting: NO marcar (lo configuramos aparte con App Hosting)
# 5. Copiar los valores del firebaseConfig que muestra
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=liebre-mvp.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=liebre-mvp
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Analytics (opcional en dev) ───
# Google Analytics 4 — Measurement ID formato G-XXXXXX
NEXT_PUBLIC_GA_ID=

# Meta Pixel — opcional, para tracking de ads
NEXT_PUBLIC_META_PIXEL_ID=
